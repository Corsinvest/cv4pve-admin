@inherits AdminComponentBase

@if (Vm.IsUnknown)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" Text="@L["Status unknown!"]" />
}
else
{
    <RadzenTabs @ref="RadzenTabsRef" TabPosition="TabPosition.Left">
        <Tabs>
            <RadzenTabsItem Text="@L["Summary"]" Icon="summarize" tab-content="@TabContent.Summary">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="10px">
                    <ToolBar ClusterName="@ClusterName" Vm="@Vm" />
                </RadzenStack>

                <Summary @ref="@SummaryRef" Vm="@Vm" ClusterName="@ClusterName" />
            </RadzenTabsItem>

            @if (CanAudit)
            {
                <RadzenTabsItem Text="@L["Config"]" Icon="settings" tab-content="@TabContent.Config">
                    <Config Vm="@Vm" ClusterName="@ClusterName" />
                </RadzenTabsItem>
            }

            @if (CanAudit && Vm.VmType == VmType.Qemu)
            {
                <RadzenTabsItem Text="@L["Guest Info"]" Icon="info" tab-content="@TabContent.QemuGeuestInfo">
                    <QemuGuestInfo Vm="@Vm" ClusterName="@ClusterName" />
                </RadzenTabsItem>
            }

            <RadzenTabsItem Text="@L["Performance"]" Icon="multiline_chart" tab-content="@TabContent.Charts">
                <Charts @ref="@ChartsRef" ClusterName="@ClusterName" Vm="@Vm" />
            </RadzenTabsItem>

            @if (CanAudit)
            {
                <RadzenTabsItem Text="@L["Task History"]" Icon="list_alt" tab-content="@TabContent.Tasks">
                    <Corsinvest.ProxmoxVE.Admin.Core.Components.ProxmoxVE.Common.Tasks @ref="@TasksRef"
                                                                                       ClusterName="@ClusterName"
                                                                                       Node="@Vm.Node"
                                                                                       VmId="@Vm.VmId"
                                                                                       Style="height:400px" />
                </RadzenTabsItem>
            }

            @if (CanBackups)
            {
                <RadzenTabsItem Text="@L["Backups"]" Icon="@PveAdminUIHelper.Icons.Backup" tab-content="@TabContent.Backup">
                    <Corsinvest.ProxmoxVE.Admin.Core.Components.ProxmoxVE.Vm.Backup.Manager Vm="@Vm"
                                                                                            ClusterName="@ClusterName"
                                                                                            Style="height:400px" />
                </RadzenTabsItem>
            }

            @if (CanReplication)
            {
                <RadzenTabsItem Text="@L["Replication"]" Icon="@PveAdminUIHelper.Icons.Replication" tab-content="@TabContent.Replication">
                    <Corsinvest.ProxmoxVE.Admin.Core.Components.ProxmoxVE.Nodes.Replication @ref="@ReplicationRef"
                                                                                            Node="@Vm.Node"
                                                                                            VmId="@Vm.VmId"
                                                                                            ClusterName="@ClusterName" />
                </RadzenTabsItem>
            }

            @if (CanSnapshots)
            {
                <RadzenTabsItem Text="@L["Snapshots"]" Icon="@PveAdminUIHelper.Icons.Snapshot" tab-content="@TabContent.Snapshot">
                    <Corsinvest.ProxmoxVE.Admin.Core.Components.ProxmoxVE.Vm.Snapshot.Manager ClusterName="@ClusterName"
                                                                                              Vm="@Vm"
                                                                                              Style="height:400px" />
                </RadzenTabsItem>
            }
        </Tabs>
    </RadzenTabs>
}
