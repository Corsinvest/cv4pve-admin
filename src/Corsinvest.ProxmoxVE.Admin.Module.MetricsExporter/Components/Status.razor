@inherits AdminComponentBase

@if (!Enabled)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" AllowClose="false" Text="@L["Metrics Exporter is disabled"]" />
}
else
{
    <RadzenPanel Text="@L["Prometheus"]" Icon="monitoring" class="rz-mb-2">
        @if (!PrometheusEnabled)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" AllowClose="false" Text="@L["Prometheus exporter is disabled"]" />
        }
        else
        {
            <RadzenStack Gap="4px">
                <RadzenLink Path="@Url" Target="_blank" Text="@L["Open metrics"]" Icon="open_in_new" />
                <RadzenText><strong>@L["Request:"]</strong> @CountRequest</RadzenText>
                <RadzenText><strong>@L["Last:"]</strong> @LastRequest</RadzenText>
            </RadzenStack>
        }
    </RadzenPanel>
}
