@inherits AdminComponentBase
@typeparam TSettings

<RadzenTemplateForm TItem="TSettings" Data="@Model" Submit="@OnSubmit" EditContext="@EditContext">
    <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween" Style="height: 100%; overflow: hidden;">
        <RadzenStack Orientation="Orientation.Vertical" Style="overflow: auto; flex: 1;">
            <SwitchField @bind-Value="@Model.Enabled" Label="@L["Enabled"]" Name="@nameof(Model.Enabled)" />

            <RadzenFormField Text="@L["Name"]" AllowFloatingLabel="false">
                <Start>
                    <RadzenIcon Icon="label" />
                </Start>
                <ChildContent>
                    <RadzenTextBox Name="@nameof(Model.Name)" @bind-Value="@Model.Name" />
                </ChildContent>
                <Helper>
                    <RadzenDataAnnotationValidator Component="@nameof(Model.Name)" />
                </Helper>
            </RadzenFormField>

            @if (EditTemplate != null)
            {
                @EditTemplate(Model)
            }
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Style="flex-shrink: 0;">
            <RadzenButton ButtonType="ButtonType.Submit"
                          Text="@Text"
                          Style="width: fit-content;"
                          Size="ButtonSize.Small" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>
