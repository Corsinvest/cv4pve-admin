@inherits AdminComponentBase

<RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
    <RadzenStack Orientation="Orientation.Horizontal">
        <RadzenFormField Text="@L["Auth Method"]" AllowFloatingLabel="false" class="@(Model.SshCredential.AuthMethod == SshAuthMethod.None ? "rz-w-50" : "rz-w-100")">
            <Start>
                <RadzenIcon Icon="key" />
            </Start>
            <ChildContent>
                <EnumDropDown @bind-Value="@Model.SshCredential.AuthMethod" />
            </ChildContent>
            <End>
                <InfoIcon>
                    <strong>@L["None"]:</strong> @L["SSH disabled, no connection will be attempted"]
                    <br />
                    <strong>@L["Password"]:</strong> @L["Authenticate using username and password"]
                    <br />
                    <strong>@L["Private Key"]:</strong> @L["Authenticate using a private key (more secure)"]
                    <br />
                    <strong>@L["Same as WEB API"]:</strong> @L["Reuse WEB API credentials (username without @realm, same password)"]
                </InfoIcon>
            </End>
        </RadzenFormField>

        @if (Model.SshCredential.AuthMethod != SshAuthMethod.None)
        {
            <RadzenFormField Text="@L["Timeout (msec)"]" AllowFloatingLabel="false" class="rz-w-100">
                <Start>
                    <RadzenIcon Icon="timer" />
                </Start>
                <ChildContent>
                    <RadzenNumeric Name="@nameof(Model.SshCredential.Timeout)" @bind-Value="@Model.SshCredential.Timeout" />
                </ChildContent>
            </RadzenFormField>
        }
    </RadzenStack>

    @if (Model.SshCredential.AuthMethod == SshAuthMethod.None)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
            @L["SSH is disabled. Features requiring SSH (snapshot size, etc.) will be skipped."]
        </RadzenAlert>
    }
    else if (Model.SshCredential.AuthMethod == SshAuthMethod.SameAsWebApi)
    {
        @if (Model.WebApi.AccessType != ClusterAccessType.Credential
             || string.IsNullOrEmpty(Model.WebApi.Username)
             || string.IsNullOrEmpty(Model.WebApi.Password))
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
                @L["SameAsWebApi requires WEB API Access Type = Credential with username and password configured."]
            </RadzenAlert>
        }
        else if (!Model.WebApi.IsPam)
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
                @L["SameAsWebApi is only valid for PAM users (e.g. root@pam). User"] <strong>@Model.WebApi.Username</strong> @L["is not a PAM user."]
            </RadzenAlert>
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
                @L["SSH will use WEB API credentials: username"] <strong>@Model.WebApi.UsernameWithoutRealm</strong> @L["with the same password."]
            </RadzenAlert>
        }
    }
    else if (Model.SshCredential.AuthMethod == SshAuthMethod.Password)
    {
        <RadzenStack Orientation="Orientation.Horizontal">
            <RadzenFormField Text="@L["Username"]" AllowFloatingLabel="false" class="rz-w-100">
                <Start>
                    <RadzenIcon Icon="account_circle" />
                </Start>
                <ChildContent>
                    <RadzenTextBox Name="@nameof(Model.SshCredential.Username)"
                                   @bind-Value="@Model.SshCredential.Username"
                                   Placeholder="root" />
                </ChildContent>
                <Helper>
                    <RadzenRequiredValidator Component="@nameof(Model.SshCredential.Username)" />
                </Helper>
            </RadzenFormField>

            <PasswordField Label="@L["Password"]"
                           Name="@nameof(Model.SshCredential.Password)"
                           @bind-Value="@Model.SshCredential.Password"
                           class="rz-w-100">
                <Helper>
                    <RadzenRequiredValidator Component="@nameof(Model.SshCredential.Password)" />
                </Helper>
            </PasswordField>
        </RadzenStack>
    }
    else if (Model.SshCredential.AuthMethod == SshAuthMethod.PrivateKey)
    {
        <RadzenStack Orientation="Orientation.Horizontal">
            <RadzenFormField Text="@L["Username"]" AllowFloatingLabel="false" class="rz-w-100">
                <Start>
                    <RadzenIcon Icon="account_circle" />
                </Start>
                <ChildContent>
                    <RadzenTextBox Name="@($"Pk{nameof(Model.SshCredential.Username)}")"
                                   @bind-Value="@Model.SshCredential.Username"
                                   Placeholder="root" />
                </ChildContent>
                <Helper>
                    <RadzenRequiredValidator Component="@($"Pk{nameof(Model.SshCredential.Username)}")" />
                </Helper>
            </RadzenFormField>

            <PasswordField Label="@L["Passphrase (optional)"]"
                           Name="@nameof(Model.SshCredential.Passphrase)"
                           @bind-Value="@Model.SshCredential.Passphrase"
                           class="rz-w-100" />
        </RadzenStack>

        <RadzenFormField Text="@L["Private Key"]" AllowFloatingLabel="false">
            <Start>
                <RadzenIcon Icon="vpn_key" />
            </Start>
            <ChildContent>
                <RadzenTextArea Name="@nameof(Model.SshCredential.PrivateKeyContent)"
                                @bind-Value="@Model.SshCredential.PrivateKeyContent"
                                Rows="6"
                                Placeholder="-----BEGIN OPENSSH PRIVATE KEY-----&#10;...&#10;-----END OPENSSH PRIVATE KEY-----"
                                Style="font-family: monospace; font-size: 0.8rem;" />
            </ChildContent>
            <End>
                <RadzenButton Icon="upload"
                              Size="ButtonSize.ExtraSmall"
                              ButtonStyle="ButtonStyle.Light"
                              title="@L["Upload private key file"]"
                              Click="@UploadKeyAsync" />
                <InputFile id="@FileInputId" OnChange="@HandleKeyFileSelectedAsync" Accept=".pem,.key,.ppk" style="display:none" />
            </End>
            <Helper>
                <RadzenRequiredValidator Component="@nameof(Model.SshCredential.PrivateKeyContent)" />
            </Helper>
        </RadzenFormField>
    }
</RadzenStack>
