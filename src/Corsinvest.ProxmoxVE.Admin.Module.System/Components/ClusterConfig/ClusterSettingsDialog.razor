@inherits AdminComponentBase
@implements IModelParameter<ClusterSettings>

<SwitchField @bind-Value="@Model.Enabled"
             Label="@L["Enabled"]"
             Name="@nameof(Model.Enabled)"
             IconOn="play_circle"
             IconOff="pause_circle" />

<RadzenFormField Text="@L["Name"]" AllowFloatingLabel="false">
    <Start>
        <RadzenIcon Icon="label" />
    </Start>
    <ChildContent>
        <RadzenTextBox Name="@nameof(Model.Name)" @bind-Value="@Model.Name" />
    </ChildContent>
    <Helper>
        <RadzenDataAnnotationValidator Component="@nameof(Model.Name)" />
    </Helper>
</RadzenFormField>

<RadzenFormField Text="@L["Description"]" AllowFloatingLabel="false">
    <Start>
        <RadzenIcon Icon="notes" />
    </Start>
    <ChildContent>
        <RadzenTextBox Name="@nameof(Model.Description)" @bind-Value="@Model.Description" />
    </ChildContent>
    <Helper>
        <RadzenDataAnnotationValidator Component="@nameof(Model.Description)" />
    </Helper>
</RadzenFormField>

<RadzenPanel Icon="map" Text="@L["Location"]">
    <RadzenStack Orientation="Orientation.Horizontal">
        <RadzenFormField Text="@L["Latitude"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="location_on" />
            </Start>
            <ChildContent>
                <RadzenNumeric Name="@nameof(Model.Latitude)" @bind-Value="@Model.Latitude" />
            </ChildContent>
        </RadzenFormField>

        <RadzenFormField Text="@L["Longitude"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="location_on" />
            </Start>
            <ChildContent>
                <RadzenNumeric Name="@nameof(Model.Longitude)" @bind-Value="@Model.Longitude" />
            </ChildContent>
        </RadzenFormField>
    </RadzenStack>
</RadzenPanel>

<RadzenPanel Text="@L["Nodes"]" Icon="@PveAdminUIHelper.Icons.Node" Selected="true">
    <NodesSettings Model="Model" />
</RadzenPanel>

<RadzenPanel Text="@L["WEB API Access"]" Icon="api" Selected="true">
    <WebApiCredentialSettings Model="@Model" ModelChanged="@StateHasChanged" />
</RadzenPanel>

<RadzenPanel Text="@L["SSH"]" Icon="terminal">
    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
        @L["Some features require SSH: NodeProtect, Updater, snapshot size calculation."]
    </RadzenText>
    <SshCredentialSettings Model="@Model" />
</RadzenPanel>

<RadzenPanel Text="@L["Feature"]" Icon="tune">
    <SubscriptionGate Size="SubscriptionGateSize.Compact">
        <SwitchField @bind-Value="@Model.AllowCalculateSnapshotSize"
                     Label="@L["Calculating the snapshot size may take some time (requires SSH)."]"
                     Name="@nameof(Model.AllowCalculateSnapshotSize)"
                     IconOn="photo_camera"
                     IconOff="no_photography"
                     Disabled="!Model.SshIsConfigured"
                     class="rz-w-100" />
    </SubscriptionGate>
</RadzenPanel>

@code
{
    [Parameter] public ClusterSettings Model { get; set; } = default!;
}
