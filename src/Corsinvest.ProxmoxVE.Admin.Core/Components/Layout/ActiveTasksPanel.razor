@inherits AdminComponentBase

@using Corsinvest.ProxmoxVE.Admin.Core.Components.TaskTracking

<RadzenPanel style="min-width: 340px; max-width: 420px; padding: 8px 0;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Style="padding: 4px 12px 8px 12px;">
        <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: bold;" Text="@L["Active Tasks"]" />
        <RadzenBadge Text="@L["{0} tasks", Tasks.Count]" BadgeStyle="BadgeStyle.Light" />
    </RadzenStack>

    <hr style="margin: 0 0 4px 0;" />

    @if (Tasks.Count == 0)
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="padding: 16px 0;">
            <RadzenImage Path="images/misc/empty-box.png" Style="height:40px; opacity:0.5;" />
            <RadzenText Text="@L[" tasks"]" TextStyle="TextStyle.Caption" class="rz-text-secondary-color" />
        </RadzenStack>
    }
    else
    {
        <RadzenListBox TValue="string"
                       Data="@Tasks"
                       Style="max-height: 320px; width: 100%; border: none;"
                       ValueProperty="Id">
            <Template Context="task">
                <TaskItemRow Item="task" OnAfterAction="OnAfterAction" />
            </Template>
        </RadzenListBox>
    }

    <hr style="margin: 4px 0 0 0;" />

    <RadzenStack Style="padding: 6px 12px 4px 12px;" @onclick="ViewAll">
        <RadzenLink Text="@L["View all tasks"]" Icon="open_in_new" Style="font-size: 0.85rem;" />
    </RadzenStack>
</RadzenPanel>
