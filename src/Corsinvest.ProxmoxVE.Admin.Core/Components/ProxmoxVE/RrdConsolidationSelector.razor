@using Corsinvest.ProxmoxVE.Api.Shared.Models.Common
@inherits AdminComponentBase

<RadzenFormField Text="@L["Consolidation"]" AllowFloatingLabel="false" class="rz-w-100">
    <Start>
        <RadzenIcon Icon="functions" />
    </Start>
    <ChildContent>
        <EnumDropDown TEnum="RrdDataConsolidation"
                      Value="@Value"
                      ValueChanged="@ValueChanged"
                      Name="@Name"
                      ReadOnly="ReadOnly" />
    </ChildContent>
    <End>
        <InfoIcon>
            <strong>@L["Average"]:</strong> @L["Smoothed trend over the period"]
            <br />
            <strong>@L["Max"]:</strong> @L["Peak detection — catches short spikes"]
        </InfoIcon>
    </End>
</RadzenFormField>

@code {
    [Parameter] public RrdDataConsolidation Value { get; set; }
    [Parameter] public EventCallback<RrdDataConsolidation> ValueChanged { get; set; }
    [Parameter] public string? Name { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
}
