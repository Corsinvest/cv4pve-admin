@using Corsinvest.ProxmoxVE.Api.Shared.Utils
@using Corsinvest.ProxmoxVE.Diagnostic.Api

@inherits AdminComponentBase

<SwitchField @bind-Value="@Model.Enabled" Label="@L["Enabled schedulation"]" Name="@nameof(Model.Enabled)" />

<CronEditor @bind-Expression="@Model.CronExpression" AllowEditor="true" />

<RadzenFormField Text="@L["Number which should will keep"]" AllowFloatingLabel="false" class="rz-w-100">
    <Start>
        <RadzenIcon Icon="layers" />
    </Start>
    <ChildContent>
        <RadzenNumeric Name="@nameof(Model.Keep)" @bind-Value="@Model.Keep" Min="1" />
    </ChildContent>
    <Helper>
        <RadzenDataAnnotationValidator Component="@nameof(Model.Keep)" />
    </Helper>
</RadzenFormField>

<Corsinvest.ProxmoxVE.Admin.Core.Components.Settings.NotifierConfigurationSelector T="Diagnostic.Settings"
                                                                                   Settings="Model" />

<RadzenRow JustifyContent="JustifyContent.Start" Gap="8px" class="rz-mb-2">
    <RadzenColumn Size="6">
        <RadzenFormField Text="@L["Max parallel requests"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="bolt" />
            </Start>
            <ChildContent>
                <RadzenNumeric Name="Model.ApiSettings.MaxParallelRequests" @bind-Value="@Model.ApiSettings.MaxParallelRequests" Min="1" />
            </ChildContent>
            <End>
                <InfoIcon>@L["Max parallel requests when fetching data (1 = sequential)."]</InfoIcon>
            </End>
            <Helper>
                <RadzenDataAnnotationValidator Component="Model.ApiSettings.MaxParallelRequests" />
            </Helper>
        </RadzenFormField>
    </RadzenColumn>
    <RadzenColumn Size="6">
        <RadzenFormField Text="@L["API timeout (seconds)"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="timer" />
            </Start>
            <ChildContent>
                <RadzenNumeric Name="Model.ApiSettings.ApiTimeout" @bind-Value="@Model.ApiSettings.ApiTimeout" Min="0" />
            </ChildContent>
            <End>
                <InfoIcon>@L["API timeout in seconds. Set to 0 to use the default."]</InfoIcon>
            </End>
            <Helper>
                <RadzenDataAnnotationValidator Component="Model.ApiSettings.ApiTimeout" />
            </Helper>
        </RadzenFormField>
    </RadzenColumn>
</RadzenRow>

<RadzenPanel Text="@L["Threshold"]" Icon="data_thresholding">
    <RadzenAccordion>
        <Items>
            <RadzenAccordionItem Text="@L["Node"]" Icon="@GetIconType(0)">
                @RenderHostThresholds(Model.ApiSettings.Node, nameof(Model.ApiSettings.Node))

                <RadzenRow JustifyContent="JustifyContent.Start" Gap="8px" class="cv4pve-dashed-box rz-mb-2">
                    <RadzenColumn Size="4">
                        <RadzenFormField Text="@L["Max vCPU Ratio"]" AllowFloatingLabel="false" class="rz-w-100">
                            <ChildContent>
                                <RadzenNumeric Name="Model.ApiSettings.Node.MaxVCpuRatio" @bind-Value="@Model.ApiSettings.Node.MaxVCpuRatio" Min="0" Step="0.5" />
                            </ChildContent>
                            <End>
                                <InfoIcon>@L["Maximum vCPU overcommit ratio (total vCPUs / physical CPUs). Default 4.0."]</InfoIcon>
                            </End>
                            <Helper>
                                <RadzenDataAnnotationValidator Component="Model.ApiSettings.Node.MaxVCpuRatio" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenFormField Text="@L["Consolidation CPU (%)"]" AllowFloatingLabel="false" class="rz-w-100">
                            <ChildContent>
                                <RadzenNumeric Name="Model.ApiSettings.Node.ConsolidationCpuThreshold" @bind-Value="@Model.ApiSettings.Node.ConsolidationCpuThreshold" Min="0" Step="1" />
                            </ChildContent>
                            <End>
                                <InfoIcon>@L["CPU utilization threshold below which a node is considered underutilized for consolidation."]</InfoIcon>
                            </End>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenFormField Text="@L["Consolidation Memory (%)"]" AllowFloatingLabel="false" class="rz-w-100">
                            <ChildContent>
                                <RadzenNumeric Name="Model.ApiSettings.Node.ConsolidationMemThreshold" @bind-Value="@Model.ApiSettings.Node.ConsolidationMemThreshold" Min="0" Step="1" />
                            </ChildContent>
                            <End>
                                <InfoIcon>@L["Memory utilization threshold below which a node is considered underutilized for consolidation."]</InfoIcon>
                            </End>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenText Text="@L["Storage"]" TextStyle="TextStyle.Subtitle1" class="rz-mt-4" Style="font-weight: bold;" />

                <SwitchField @bind-Value="@Model.ApiSettings.Node.Smart.Enabled"
                             Label="@L["S.M.A.R.T."]"
                             Name="@($"Model.ApiSettings.Node.Smart.{nameof(Model.ApiSettings.Node.Smart.Enabled)}")"
                             class="rz-mb-2" />

                @if (Model.ApiSettings.Node.Smart.Enabled)
                {
                    <RadzenRow JustifyContent="JustifyContent.SpaceBetween" class="cv4pve-dashed-box rz-mb-2">
                        <RadzenColumn Size="4">
                            @RenderThreshold(L["Temperature (°C)"], "Model.ApiSettings.Node.Smart.Temperature", Model.ApiSettings.Node.Smart.Temperature)
                        </RadzenColumn>
                        <RadzenColumn Size="4">
                            @RenderThreshold(L["SSD Wearout (%)"], "Model.ApiSettings.Node.Smart.SsdWearout", Model.ApiSettings.Node.Smart.SsdWearout)
                        </RadzenColumn>
                    </RadzenRow>
                }

                <SwitchField @bind-Value="@Model.ApiSettings.Node.NodeStorage.ZfsDetail"
                             Label="@L["ZFS detail checks"]"
                             Name="Model.ApiSettings.Node.NodeStorage.ZfsDetail"
                             class="rz-mb-2" />

                <SwitchField @bind-Value="@Model.ApiSettings.Node.NodeStorage.LvmThinMetadata"
                             Label="@L["LVM-thin metadata check"]"
                             Name="Model.ApiSettings.Node.NodeStorage.LvmThinMetadata"
                             class="rz-mb-2" />
            </RadzenAccordionItem>

            <RadzenAccordionItem Text="@L["Qemu"]" Icon="@GetIconType(1)">
                @RenderHostThresholds(Model.ApiSettings.Qemu, nameof(Model.ApiSettings.Qemu))
            </RadzenAccordionItem>

            <RadzenAccordionItem Text="@L["Lxc"]" Icon="@GetIconType(2)">
                @RenderHostThresholds(Model.ApiSettings.Lxc, nameof(Model.ApiSettings.Lxc))
            </RadzenAccordionItem>

            <RadzenAccordionItem Text="@L["Storage"]" Icon="@PveAdminUIHelper.Icons.Storage">
                @RenderRrd(Model.ApiSettings.Storage.Rrd, "Model.ApiSettings.Storage.Rrd")
                <RadzenRow JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenColumn Size="4">
                        @RenderThreshold(L["Usage"], "Model.ApiSettings.Storage.Threshold", Model.ApiSettings.Storage.Threshold)
                    </RadzenColumn>
                </RadzenRow>
                @RenderPsiPressure(Model.ApiSettings.Storage.Rrd, "Model.ApiSettings.Storage.Rrd")
            </RadzenAccordionItem>

            <RadzenAccordionItem Text="@L["Snapshot"]" Icon="camera_alt">
                <SwitchField @bind-Value="@Model.ApiSettings.Snapshot.Enabled"
                             Label="@L["Enable"]"
                             Name="Model.ApiSettings.Snapshot.Enabled"
                             class="rz-mb-2" />

                @if (Model.ApiSettings.Snapshot.Enabled)
                {
                    <RadzenRow JustifyContent="JustifyContent.SpaceBetween" class="cv4pve-dashed-box rz-mb-2">
                        <RadzenColumn Size="4">
                            <RadzenFormField Text="@L["Max Count"]" AllowFloatingLabel="false" class="rz-w-100">
                                <ChildContent>
                                    <RadzenNumeric Name="Model.ApiSettings.Snapshot.MaxCount" @bind-Value="@Model.ApiSettings.Snapshot.MaxCount" Min="0" />
                                </ChildContent>
                                <End>
                                    <InfoIcon>@L["Maximum number of snapshots per VM/LXC before raising a warning. Set to 0 to disable."]</InfoIcon>
                                </End>
                                <Helper>
                                    <RadzenDataAnnotationValidator Component="Model.ApiSettings.Snapshot.MaxCount" />
                                </Helper>
                            </RadzenFormField>
                        </RadzenColumn>

                        <RadzenColumn Size="4">
                            <RadzenFormField Text="@L["Max Age (days)"]" AllowFloatingLabel="false" class="rz-w-100">
                                <ChildContent>
                                    <RadzenNumeric Name="Model.ApiSettings.Snapshot.MaxAgeDays" @bind-Value="@Model.ApiSettings.Snapshot.MaxAgeDays" Min="0" />
                                </ChildContent>
                                <End>
                                    <InfoIcon>@L["Maximum age in days for snapshots before raising a warning. Set to 0 to disable."]</InfoIcon>
                                </End>
                                <Helper>
                                    <RadzenDataAnnotationValidator Component="Model.ApiSettings.Snapshot.MaxAgeDays" />
                                </Helper>
                            </RadzenFormField>
                        </RadzenColumn>
                    </RadzenRow>
                }
            </RadzenAccordionItem>

            <RadzenAccordionItem Text="@L["Backup"]" Icon="backup">
                <SwitchField @bind-Value="@Model.ApiSettings.Backup.Enabled"
                             Label="@L["Enable"]"
                             Name="@($"Model.ApiSettings.Backup.{nameof(Model.ApiSettings.Backup.Enabled)}")"
                             class="rz-mb-2" />

                @if (Model.ApiSettings.Backup.Enabled)
                {
                    <RadzenRow JustifyContent="JustifyContent.SpaceBetween" class="cv4pve-dashed-box rz-mb-2">
                        <RadzenColumn Size="4">
                            <RadzenFormField Text="@L["Max Age (days)"]" AllowFloatingLabel="false" class="rz-w-100">
                                <ChildContent>
                                    <RadzenNumeric Name="Model.ApiSettings.Backup.MaxAgeDays" @bind-Value="@Model.ApiSettings.Backup.MaxAgeDays" Min="0" />
                                </ChildContent>
                                <End>
                                    <InfoIcon>@L["Old backups still present on storage waste space. Set to 0 to disable."]</InfoIcon>
                                </End>
                                <Helper>
                                    <RadzenDataAnnotationValidator Component="Model.ApiSettings.Backup.MaxAgeDays" />
                                </Helper>
                            </RadzenFormField>
                        </RadzenColumn>

                        <RadzenColumn Size="4">
                            <RadzenFormField Text="@L["Recent Days"]" AllowFloatingLabel="false" class="rz-w-100">
                                <ChildContent>
                                    <RadzenNumeric Name="Model.ApiSettings.Backup.RecentDays" @bind-Value="@Model.ApiSettings.Backup.RecentDays" Min="0" />
                                </ChildContent>
                                <End>
                                    <InfoIcon>@L["If no backup exists within this window, a warning is raised (RPO violation). Set to 0 to disable."]</InfoIcon>
                                </End>
                                <Helper>
                                    <RadzenDataAnnotationValidator Component="Model.ApiSettings.Backup.RecentDays" />
                                </Helper>
                            </RadzenFormField>
                        </RadzenColumn>
                    </RadzenRow>
                }
            </RadzenAccordionItem>

            <RadzenAccordionItem Text="@L["CVE"]" Icon="shield">
                <SwitchField @bind-Value="@Model.ApiSettings.Cve.DebianTrackerEnabled"
                             Label="@L["Debian Security Tracker"]"
                             Name="Model.ApiSettings.Cve.DebianTrackerEnabled"
                             class="rz-mb-2" />

                <SwitchField @bind-Value="@Model.ApiSettings.Cve.NvdEnabled"
                             Label="@L["NVD checks for Proxmox-specific CVE"]"
                             Name="Model.ApiSettings.Cve.NvdEnabled"
                             class="rz-mb-2" />

                <RadzenRow JustifyContent="JustifyContent.Start" class="cv4pve-dashed-box rz-mb-2">
                    <RadzenColumn Size="4">
                        <RadzenFormField Text="@L["Min CVSS score"]" AllowFloatingLabel="false" class="rz-w-100">
                            <ChildContent>
                                <RadzenNumeric Name="Model.ApiSettings.Cve.MinCvssScore" @bind-Value="@Model.ApiSettings.Cve.MinCvssScore" Min="0" Max="10" Step="0.5" />
                            </ChildContent>
                            <End>
                                <InfoIcon>@L["Minimum CVSS v3 base score (0.0-10.0) to report. Default 7.0 (HIGH + CRITICAL). Set to 0 to report all."]</InfoIcon>
                            </End>
                            <Helper>
                                <RadzenDataAnnotationValidator Component="Model.ApiSettings.Cve.MinCvssScore" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenAccordionItem>
        </Items>
    </RadzenAccordion>
</RadzenPanel>

@code
{
    private RenderFragment RenderRrd(SettingsRrd rrd, string baseProp) => __builder =>
    {
        <RadzenText Text="@L["RRD Data"]" TextStyle="TextStyle.Subtitle2" class="rz-mt-2" Style="font-weight: bold;" />
        <RadzenRow JustifyContent="JustifyContent.Start" Gap="8px" class="rz-mb-2 cv4pve-dashed-box">
            <RadzenColumn Size="4">
                <RrdTimeFrameSelector @bind-Value="@rrd.TimeFrame" Name="@($"{baseProp}.{nameof(rrd.TimeFrame)}")" />
            </RadzenColumn>

            <RadzenColumn Size="4">
                <RrdConsolidationSelector @bind-Value="@rrd.Consolidation" Name="@($"{baseProp}.{nameof(rrd.Consolidation)}")" />
            </RadzenColumn>
        </RadzenRow>
    };

    private RenderFragment RenderPsiPressure(SettingsRrd rrd, string baseProp) => __builder =>
    {
        var pressureProp = $"{baseProp}.{nameof(rrd.Pressure)}";
        <RadzenText Text="@L["PSI Pressure (PVE 9.0+)"]" TextStyle="TextStyle.Subtitle2" class="rz-mt-2" Style="font-weight: bold;" />
        <RadzenRow JustifyContent="JustifyContent.SpaceBetween" class="cv4pve-dashed-box rz-mb-2">
            <RadzenColumn Size="4">
                @RenderThreshold(L["CPU (some)"], $"{pressureProp}.{nameof(rrd.Pressure.Cpu)}", rrd.Pressure.Cpu)
            </RadzenColumn>
            <RadzenColumn Size="4">
                @RenderThreshold(L["I/O (full)"], $"{pressureProp}.{nameof(rrd.Pressure.IoFull)}", rrd.Pressure.IoFull)
            </RadzenColumn>
            <RadzenColumn Size="4">
                @RenderThreshold(L["Memory (full)"], $"{pressureProp}.{nameof(rrd.Pressure.MemoryFull)}", rrd.Pressure.MemoryFull)
            </RadzenColumn>
        </RadzenRow>
    };

    private RenderFragment RenderHostThresholds(SettingsThresholdHost host, string propertyName) => __builder =>
    {
        var basePropertyName = $"Model.ApiSettings.{propertyName}";
        var rrdProp = $"{basePropertyName}.{nameof(host.Rrd)}";

        @RenderRrd(host.Rrd, rrdProp)

        <RadzenText Text="@L["Thresholds"]" TextStyle="TextStyle.Subtitle2" class="rz-mt-2" Style="font-weight: bold;" />
        <RadzenRow JustifyContent="JustifyContent.SpaceBetween" class="cv4pve-dashed-box rz-mb-2">
            <RadzenColumn Size="3">
                @RenderThreshold(L["CPU"], $"{basePropertyName}.{nameof(host.Cpu)}", host.Cpu)
            </RadzenColumn>
            <RadzenColumn Size="3">
                @RenderThreshold(L["Memory"], $"{basePropertyName}.{nameof(host.Memory)}", host.Memory)
            </RadzenColumn>
            <RadzenColumn Size="3">
                @RenderThreshold(L["Network"], $"{basePropertyName}.{nameof(host.Network)}", host.Network)
            </RadzenColumn>
            <RadzenColumn Size="3">
                @RenderThreshold(L["Health Score"], $"{basePropertyName}.{nameof(host.HealthScore)}", host.HealthScore)
            </RadzenColumn>
        </RadzenRow>

        @RenderPsiPressure(host.Rrd, rrdProp)
    };

    private RenderFragment RenderThreshold<T>(string title, string pathBaseProperty, SettingsThreshold<T> threshold, bool disabled = false)
        where T : struct => __builder =>
    {
        <RadzenText Text="@L[title]" TextAlign="TextAlign.Center" TextStyle="TextStyle.Subtitle2" />

        var nameWarning = $"{pathBaseProperty}.{nameof(threshold.Warning)}";
        <RadzenFormField Text="@L["Warning"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="warning" IconColor="@Colors.WarningDark" />
            </Start>
            <ChildContent>
                <RadzenNumeric TValue="T" Name="@nameWarning" @bind-Value="@threshold.Warning" Min="0" Disabled="@disabled" />
            </ChildContent>
            <Helper>
                <RadzenDataAnnotationValidator Component="@nameWarning" />
            </Helper>
        </RadzenFormField>

        var nameCritical = $"{pathBaseProperty}.{nameof(threshold.Critical)}";
        <RadzenFormField Text="@L["Critical"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="error" IconColor="@Colors.DangerDark" />
            </Start>
            <ChildContent>
                <RadzenNumeric TValue="T" Name="@nameCritical" @bind-Value="@threshold.Critical" Min="0" Disabled="@disabled" />
            </ChildContent>
            <Helper>
                <RadzenDataAnnotationValidator Component="@nameCritical" />
            </Helper>
        </RadzenFormField>
    };
}
