@inherits AdminComponentBase

<RadzenStack Orientation="Orientation.Vertical">
    <RadzenStack Orientation="Orientation.Horizontal">
        <RadzenFormField Text="@L["Access Type"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="vpn_key" />
            </Start>
            <ChildContent>
                <RadzenDropDown TValue="ClusterAccessType"
                                Name="@nameof(Model.WebApi.AccessType)"
                                @bind-Value="@Model.WebApi.AccessType"
                                Data="@(Enum.GetValues<ClusterAccessType>())" />
            </ChildContent>
            <End>
                <InfoIcon>
                    <strong>@L["Credential"]:</strong> @L["Authenticate using username and password"]
                    <br />
                    <strong>@L["ApiToken"]:</strong> @L["Authenticate using API token (more secure)"]
                </InfoIcon>
            </End>
        </RadzenFormField>

        <RadzenFormField Text="@L["Timeout (msec)"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="timer" />
            </Start>
            <ChildContent>
                <RadzenNumeric Name="@nameof(Model.WebApi.Timeout)" @bind-Value="@Model.WebApi.Timeout" />
            </ChildContent>
            <Helper>
                <RadzenDataAnnotationValidator Component="@nameof(Model.WebApi.Timeout)" />
            </Helper>
        </RadzenFormField>
    </RadzenStack>

    @if (Model.WebApi.AccessType == ClusterAccessType.Credential)
    {
        <RadzenStack Orientation="Orientation.Horizontal">
            <RadzenFormField Text="@L["Username"]" AllowFloatingLabel="false" class="rz-w-100">
                <Start>
                    <RadzenIcon Icon="account_circle" />
                </Start>
                <ChildContent>
                    <RadzenTextBox Name="@($"Api{nameof(Model.WebApi.Username)}")"
                                   @bind-Value="@Model.WebApi.Username"
                                   Placeholder="USER@REALM" />
                </ChildContent>
                <Helper>
                    <RadzenRequiredValidator Component="@($"Api{nameof(Model.WebApi.Username)}")" />
                </Helper>
            </RadzenFormField>

            <PasswordField Label="@L["Password"]"
                           Name="@nameof(Model.WebApi.Password)"
                           @bind-Value="@Model.WebApi.Password"
                           class="rz-w-100">
                <Helper>
                    <RadzenRequiredValidator Component="@nameof(Model.WebApi.Password)" />
                </Helper>
            </PasswordField>
        </RadzenStack>
    }
    else if (Model.WebApi.AccessType == ClusterAccessType.ApiToken)
    {
        <PasswordField @bind-Value="@Model.WebApi.ApiToken"
                       Label="@L["API Token"]"
                       Name="@nameof(Model.WebApi.ApiToken)"
                       Placeholder="user@realm!tokenid=secret"
                       class="rz-w-100">
            <End>
                <RadzenButton Icon="vpn_key"
                              Size="ButtonSize.ExtraSmall"
                              ButtonStyle="ButtonStyle.Warning"
                              title="@L["Create API Token automatically"]"
                              Click="@CreateApiTokenAsync" />
            </End>
            <Helper>
                <RadzenRequiredValidator Component="@nameof(Model.WebApi.ApiToken)" />
            </Helper>
        </PasswordField>
    }

    <SwitchField @bind-Value="@Model.WebApi.ValidateCertificate"
                 Label="@L["Validate SSL Certificate"]"
                 Name="@nameof(Model.WebApi.ValidateCertificate)"
                 IconOn="lock"
                 IconOff="no_encryption"
                 class="rz-w-100" />
</RadzenStack>
