@inherits AdminComponentBase

<RadzenStack Gap="1rem">
    <RadzenFormField Text="@L["Username"]" AllowFloatingLabel="false">
        <Start><RadzenIcon Icon="account_circle" /></Start>
        <ChildContent>
            <RadzenTextBox @bind-Value="@Username"
                           Name="Username"
                           Placeholder="user@realm"
                           aria-label="@L["Username"]" />
        </ChildContent>
        <Helper>
            <RadzenRequiredValidator Component="Username" />
        </Helper>
    </RadzenFormField>

    <PasswordField @bind-Value="@Password"
                   Label="@L["Password"]"
                   Name="Password">
        <Helper>
            <RadzenRequiredValidator Component="Password" />
        </Helper>
    </PasswordField>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="@L["Cancel"]"
                      Click="@(() => DialogService.Close(null))"
                      ButtonStyle="ButtonStyle.Light" />
        <RadzenButton Text="@L["Confirm"]"
                      Click="@OnConfirmAsync"
                      ButtonStyle="ButtonStyle.Primary"
                      Disabled="@(string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password))" />
    </RadzenStack>
</RadzenStack>

@code {
    [CascadingParameter] public DialogService DialogService { get; set; } = default!;

    private string Username { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;

    private Task OnConfirmAsync()
    {
        DialogService.Close((Username, Password));
        return Task.CompletedTask;
    }
}
