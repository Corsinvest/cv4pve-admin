@inherits AdminComponentBase

<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="@L["General"]" Icon="tune">

            <RadzenStack Orientation="Orientation.Vertical">

                <RadzenStack Orientation="Orientation.Horizontal">
                    <RadzenFormField Text="@L["Vm Ids"]" AllowFloatingLabel="false">
                        <Start><RadzenIcon Icon="computer" /></Start>
                        <ChildContent>
                            <RadzenTextBox Name="@nameof(Model.VmIds)" @bind-Value="@Model.VmIds" />
                        </ChildContent>
                        <Helper>
                            <RadzenDataAnnotationValidator Component="@nameof(Model.VmIds)" />
                        </Helper>
                    </RadzenFormField>

                    <RadzenFormField Text="@L["Feature"]" AllowFloatingLabel="false" class="rz-w-100">
                        <Start><RadzenIcon Icon="tune" /></Start>
                        <ChildContent>
                            <RadzenDropDown Name="@nameof(VmFeature)"
                                            Multiple="true"
                                            AllowClear="true"
                                            Placeholder="@L["All (leave empty)"]"
                                            @bind-Value="@VmFeatures"
                                            Data="@(Enum.GetValues<VmFeature>().Where(a => a != VmFeature.All))">
                                <Template>@L[((Enum)(object)context).GetDisplayName()]</Template>
                            </RadzenDropDown>
                        </ChildContent>
                        <End>
                            <InfoIcon>
                                <strong>@L["Network"]:</strong> @L["Network interfaces"]<br />
                                <strong>@L["Disks"]:</strong> @L["Disk configuration"]<br />
                                <strong>@L["QEMU Guest Info"]:</strong> @L["Guest agent information"]<br />
                                <strong>@L["RRD Data"]:</strong> @L["Performance metrics history"]<br />
                                <strong>@L["Backup"]:</strong> @L["Backup jobs and status"]<br />
                                <strong>@L["Replications"]:</strong> @L["Replication jobs"]<br />
                                <strong>@L["Snapshots"]:</strong> @L["Snapshot list"]<br />
                                <strong>@L["Snapshots Size"]:</strong> @L["Snapshot disk usage (requires SSH)"]
                            </InfoIcon>
                        </End>
                    </RadzenFormField>
                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal">
                    <RadzenFormField Text="@L["Node Names"]" AllowFloatingLabel="false">
                        <Start><RadzenIcon Icon="@PveAdminUIHelper.Icons.Node" /></Start>
                        <ChildContent>
                            <RadzenTextBox Name="@nameof(Model.NodeNames)" @bind-Value="@Model.NodeNames" />
                        </ChildContent>
                        <Helper>
                            <RadzenDataAnnotationValidator Component="@nameof(Model.NodeNames)" />
                        </Helper>
                    </RadzenFormField>

                    <RadzenFormField Text="@L["Feature"]" AllowFloatingLabel="false" class="rz-w-100">
                        <Start><RadzenIcon Icon="tune" /></Start>
                        <ChildContent>
                            <RadzenDropDown Name="@nameof(NodeFeature)"
                                            Multiple="true"
                                            AllowClear="true"
                                            Placeholder="@L["All (leave empty)"]"
                                            @bind-Value="@NodeFeatures"
                                            Data="@(Enum.GetValues<NodeFeature>().Where(a => a != NodeFeature.All))">
                                <Template>@L[((Enum)(object)context).GetDisplayName()]</Template>
                            </RadzenDropDown>
                        </ChildContent>
                        <End>
                            <InfoIcon>
                                <strong>@L["Services"]:</strong> @L["System services status"]<br />
                                <strong>@L["Network"]:</strong> @L["Network interfaces"]<br />
                                <strong>@L["Replications"]:</strong> @L["Replication jobs"]<br />
                                <strong>@L["Disks"]:</strong> @L["Disk configuration"]<br />
                                <strong>@L["Smart Disks"]:</strong> @L["SMART disk health data"]<br />
                                <strong>@L["RRD Data"]:</strong> @L["Performance metrics history"]<br />
                                <strong>@L["APT Info"]:</strong> @L["Available package updates"]<br />
                                <strong>@L["Packages Versions"]:</strong> @L["Installed package versions"]<br />
                                <strong>@L["Snapshots Size"]:</strong> @L["Snapshot disk usage (requires SSH)"]
                            </InfoIcon>
                        </End>
                    </RadzenFormField>
                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal">
                    <RadzenFormField Text="@L["Storage Names"]" AllowFloatingLabel="false">
                        <Start><RadzenIcon Icon="@PveAdminUIHelper.Icons.Storage" /></Start>
                        <ChildContent>
                            <RadzenTextBox Name="@nameof(Model.StorageNames)" @bind-Value="@Model.StorageNames" />
                        </ChildContent>
                        <Helper>
                            <RadzenDataAnnotationValidator Component="@nameof(Model.StorageNames)" />
                        </Helper>
                    </RadzenFormField>

                    <RadzenFormField Text="@L["Feature"]" AllowFloatingLabel="false" class="rz-w-100">
                        <Start><RadzenIcon Icon="tune" /></Start>
                        <ChildContent>
                            <RadzenDropDown Name="@nameof(StorageFeature)"
                                            Multiple="true"
                                            AllowClear="true"
                                            Placeholder="@L["All (leave empty)"]"
                                            @bind-Value="@StorageFeatures"
                                            Data="@(Enum.GetValues<StorageFeature>().Where(a => a != StorageFeature.All))">
                                <Template>@L[((Enum)(object)context).GetDisplayName()]</Template>
                            </RadzenDropDown>
                        </ChildContent>
                        <End>
                            <InfoIcon>
                                <strong>@L["Content"]:</strong> @L["Storage content list"]<br />
                                <strong>@L["RRD Data"]:</strong> @L["Performance metrics history"]
                            </InfoIcon>
                        </End>
                    </RadzenFormField>
                </RadzenStack>

            </RadzenStack>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>
