@inherits AdminComponentBase

<RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
    <RadzenStack Orientation="Orientation.Horizontal">
        <RadzenFormField Text="@L["Auth Method"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="key" />
            </Start>
            <ChildContent>
                <RadzenDropDown TValue="SshAuthMethod"
                                @bind-Value="@Model.AuthMethod"
                                Data="@(Enum.GetValues<SshAuthMethod>())" />
            </ChildContent>
            <End>
                <InfoIcon>
                    <strong>@L["Password"]:</strong> @L["Authenticate using username and password"]
                    <br />
                    <strong>@L["Private Key"]:</strong> @L["Authenticate using a private key (more secure)"]
                </InfoIcon>
            </End>
        </RadzenFormField>

        <RadzenFormField Text="@L["Timeout (msec)"]" AllowFloatingLabel="false" class="rz-w-100">
            <Start>
                <RadzenIcon Icon="timer" />
            </Start>
            <ChildContent>
                <RadzenNumeric Name="@nameof(Model.Timeout)" @bind-Value="@Model.Timeout" />
            </ChildContent>
        </RadzenFormField>
    </RadzenStack>

    @if (Model.AuthMethod == SshAuthMethod.Password)
    {
        <RadzenStack Orientation="Orientation.Horizontal">
            <RadzenFormField Text="@L["Username"]" AllowFloatingLabel="false" class="rz-w-100">
                <Start>
                    <RadzenIcon Icon="account_circle" />
                </Start>
                <ChildContent>
                    <RadzenTextBox Name="@nameof(Model.Username)"
                                   @bind-Value="@Model.Username"
                                   Placeholder="root" />
                </ChildContent>
                <Helper>
                    <RadzenRequiredValidator Component="@nameof(Model.Username)" />
                </Helper>
            </RadzenFormField>

            <PasswordField Label="@L["Password"]"
                           Name="@nameof(Model.Password)"
                           @bind-Value="@Model.Password"
                           class="rz-w-100">
                <Helper>
                    <RadzenRequiredValidator Component="@nameof(Model.Password)" />
                </Helper>
            </PasswordField>
        </RadzenStack>
    }
    else
    {
        <RadzenStack Orientation="Orientation.Horizontal">
            <RadzenFormField Text="@L["Username"]" AllowFloatingLabel="false" class="rz-w-100">
                <Start>
                    <RadzenIcon Icon="account_circle" />
                </Start>
                <ChildContent>
                    <RadzenTextBox Name="@($"Pk{nameof(Model.Username)}")"
                                   @bind-Value="@Model.Username"
                                   Placeholder="root" />
                </ChildContent>
                <Helper>
                    <RadzenRequiredValidator Component="@($"Pk{nameof(Model.Username)}")" />
                </Helper>
            </RadzenFormField>

            <PasswordField Label="@L["Passphrase (optional)"]"
                           Name="@nameof(Model.Passphrase)"
                           @bind-Value="@Model.Passphrase"
                           class="rz-w-100" />
        </RadzenStack>

        <RadzenFormField Text="@L["Private Key"]" AllowFloatingLabel="false">
            <Start>
                <RadzenIcon Icon="vpn_key" />
            </Start>
            <ChildContent>
                <RadzenTextArea Name="@nameof(Model.PrivateKeyContent)"
                                @bind-Value="@Model.PrivateKeyContent"
                                Rows="6"
                                Placeholder="-----BEGIN OPENSSH PRIVATE KEY-----&#10;...&#10;-----END OPENSSH PRIVATE KEY-----"
                                Style="font-family: monospace; font-size: 0.8rem;" />
            </ChildContent>
            <End>
                <RadzenButton Icon="upload"
                              Size="ButtonSize.ExtraSmall"
                              ButtonStyle="ButtonStyle.Light"
                              title="@L["Upload private key file"]"
                              Click="@UploadKeyAsync" />
                <InputFile id="@FileInputId" OnChange="@HandleKeyFileSelectedAsync" Accept=".pem,.key,.ppk" style="display:none" />
            </End>
            <Helper>
                <RadzenRequiredValidator Component="@nameof(Model.PrivateKeyContent)" />
            </Helper>
        </RadzenFormField>
    }
</RadzenStack>
