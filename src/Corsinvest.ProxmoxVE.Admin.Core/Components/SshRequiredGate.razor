@inherits AdminComponentBase
@inject ISettingsService SettingsService

@if (SshEnabled)
{
    @ChildContent
}
else
{
    <RadzenAlert AlertStyle="AlertStyle.Warning"
                 AllowClose="false"
                 Text="@L["SSH is not configured for this cluster. Please configure SSH in the cluster settings."]" />
}

@code {
    [Parameter, EditorRequired] public string ClusterName { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool SshEnabled => SettingsService.GetClusterSettings(ClusterName)?.SshIsConfigured ?? false;
}
