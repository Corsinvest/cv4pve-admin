@inherits AdminComponentBase

<RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween" Style="height: 100%; overflow: hidden;">
    <ResourcesEx @bind-ClusterNames="@ClusterNames"
                 Style="@Style"
                 UseProgressBarPercentage="@UseProgressBarPercentage"
                 DescriptionAsLink="@DescriptionAsLink"
                 FilterExpression="@FilterExpression"
                 SelectedItemExpression="@SelectedItemExpression"
                 ShowSnapshotSize="@ShowSnapshotSize"
                 ShowOsInfo="@ShowOsInfo"
                 Template="@Template"
                 ShowLoading="@ShowLoading"
                 AvailableCommands="@AvailableCommands"
                 PropertyIconStatus="@PropertyIconStatus"
                 IconStatus="@IconStatus"
                 ResourceType="@ResourceType"
                 TemplateToolbar="@TemplateToolbar"
                 SelectionMode="@SelectionMode"
                 @bind-DataGridSettings="DataGridSettings"
                 @bind-SelectedItems="@SelectedItems"
                 PickableColumns="@PickableColumns"
                 AllowColumnPicking="@AllowColumnPicking"
                 RefreshInterval="@RefreshInterval"
                 AdditionalAttributes="@AdditionalAttributes" />

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Style="flex-shrink: 0;">
        <RadzenButton Click="OnSelect"
                      Text="@L["Select"]"
                      Style="width: fit-content;"
                      Size="ButtonSize.Small" />
    </RadzenStack>
</RadzenStack>
