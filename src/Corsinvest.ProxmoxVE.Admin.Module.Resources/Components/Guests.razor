@inherits AdminComponentBase

<ResourcesView @ref="ResourcesExRef"
             OnDataLoaded="OnDataLoadedAsync"
             FilterExpression="@((a, _) => a.ResourceType == ClusterResourceType.Vm)"
             ClusterNames="@([ClusterName])"
             PropertyIconStatus="ResourcesViewPropertyIconStatus.Status"
             IconStatus="ResourceColumnIconStatus.IconAndText"
             ResourceType="ClusterResourceType.Vm"
             ShowSnapshotSize="true"
             UseProgressBarPercentage="false"
             RefreshInterval="10"
             @bind-DataGridSettings="DataGridSettings"
             ShowOsInfo="@ShowOsInfo"
             ShowViewTypeSelector="true"
             DescriptionAsLink="true">

    <TemplateToolbar>
        <RadzenToggleButton @bind-Value="@ShowOsInfo"
                            @bind-Value:after="ShowOsInfoAfter"
                            Icon="computer"
                            title="@L["Show OS Info"]"
                            Size="ButtonSize.Small"
                            ButtonStyle="ButtonStyle.Light" />
    </TemplateToolbar>

    <Template>
        <RadzenPanel>
            <Corsinvest.ProxmoxVE.Admin.Core.Components.ProxmoxVE.Vm.Manager Vm="context"
                                                                             ClusterName="@ClusterName" />
        </RadzenPanel>
    </Template>
</ResourcesView>
