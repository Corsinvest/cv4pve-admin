@inherits AdminComponentBase
@implements IModelParameter<Settings>

<SwitchField @bind-Value="@Model.Enabled"
             Label="@L["Enabled"]"
             Name="@nameof(Model.Enabled)"
             IconOn="play_circle"
             IconOff="pause_circle" />

<RadzenFormField Text="@L["Output Format"]" Style="width:100%">
    <Start>
        <RadzenIcon Icon="output" />
    </Start>
    <ChildContent>
        <RadzenDropDown TValue="ToolOutputFormat"
                        Name="@nameof(Model.OutputFormat)"
                        @bind-Value="@Model.OutputFormat"
                        Data="@(Enum.GetValues<ToolOutputFormat>())" />
    </ChildContent>
    <End>
        <InfoIcon>
            <ul style="margin:0; padding-left:1.2em;">
                <li><strong>JsonCompact</strong> — @L["Compact JSON tabular (~40% fewer tokens than JsonNormal)"]</li>
                <li><strong>JsonNormal</strong> — @L["Standard JSON array of objects"]</li>
                <li><strong>Toon</strong> — @L["Token-Oriented Object Notation (~55% fewer tokens than JsonNormal)"]</li>
                <li><strong>Csv</strong> — @L["CSV with header row (minimal tokens, best for tabular data)"]</li>
            </ul>
        </InfoIcon>
    </End>
</RadzenFormField>

@code
{
    [Parameter] public Settings Model { get; set; } = default!;
}
