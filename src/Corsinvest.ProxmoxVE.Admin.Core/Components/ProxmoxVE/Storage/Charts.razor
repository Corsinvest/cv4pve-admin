@inherits AdminComponentBase

<RadzenStack Orientation="Orientation.Vertical">
    <RadzenRow>
        <RadzenColumn Size="6">
            <RrdTimeFrameSelector @bind-Value="@RrdDataTimeFrame" @bind-Value:after="@RefreshDataAsync" />
        </RadzenColumn>

        <RadzenColumn Size="6">
            <RrdConsolidationSelector @bind-Value="@RrdDataConsolidation" @bind-Value:after="@RefreshDataAsync" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow>
        <RadzenColumn Size="12">
            <Chart Data="@Items" />
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>
